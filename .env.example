# Confluent Cloud — Kafka credentials
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-2.aws.confluent.cloud:9092
KAFKA_API_KEY=your_api_key
KAFKA_API_SECRET=your_api_secret

# Grafana Cloud — para configurar el datasource AWS CloudWatch en la UI
GRAFANA_URL=https://your-stack.grafana.net
GRAFANA_USER_ID=your_numeric_user_id
GRAFANA_API_TOKEN=your_api_token
